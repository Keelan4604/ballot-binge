generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Jurisdiction {
  id           String          @id @default(cuid())
  name         String
  abbreviation String          @unique
  type         String          @default("state")
  candidates   Candidate[]
  measures     BallotMeasure[]
  createdAt    DateTime        @default(now())
}

model Topic {
  id          String           @id @default(cuid())
  name        String           @unique
  slug        String           @unique
  description String?
  icon        String?
  candidates  CandidateTopic[]
  measures    MeasureTopic[]
  createdAt   DateTime         @default(now())
}

model Candidate {
  id             String           @id @default(cuid())
  name           String
  office         String
  party          String?
  jurisdictionId String
  jurisdiction   Jurisdiction     @relation(fields: [jurisdictionId], references: [id])
  shortSummary   String
  longSummary    String?
  imageUrl       String?
  websiteUrl     String?
  electionDate   String?
  topics         CandidateTopic[]
  stances        Stance[]
  swipes         Swipe[]
  sortOrder      Int              @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model CandidateTopic {
  candidateId String
  topicId     String
  candidate   Candidate @relation(fields: [candidateId], references: [id])
  topic       Topic     @relation(fields: [topicId], references: [id])

  @@id([candidateId, topicId])
}

model Stance {
  id          String    @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id])
  topic       String
  position    String
  summary     String
  createdAt   DateTime  @default(now())
}

model BallotMeasure {
  id             String         @id @default(cuid())
  title          String
  measureCode    String?
  jurisdictionId String
  jurisdiction   Jurisdiction   @relation(fields: [jurisdictionId], references: [id])
  electionDate   String?
  category       String?
  shortSummary   String
  longSummary    String?
  yesMeans       String?
  noMeans        String?
  proArguments   String?
  conArguments   String?
  topics         MeasureTopic[]
  swipes         Swipe[]
  sortOrder      Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model MeasureTopic {
  measureId String
  topicId   String
  measure   BallotMeasure @relation(fields: [measureId], references: [id])
  topic     Topic         @relation(fields: [topicId], references: [id])

  @@id([measureId, topicId])
}

model Swipe {
  id          String         @id @default(cuid())
  sessionId   String
  itemType    String
  candidateId String?
  candidate   Candidate?     @relation(fields: [candidateId], references: [id])
  measureId   String?
  measure     BallotMeasure? @relation(fields: [measureId], references: [id])
  choice      String
  createdAt   DateTime       @default(now())

  @@index([sessionId])
}

model UserProfile {
  id        String   @id @default(cuid())
  name      String?
  party     String?
  city      String?
  state     String?
  email     String?
  createdAt DateTime @default(now())
}
